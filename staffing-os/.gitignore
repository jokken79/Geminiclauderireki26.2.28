# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env.local
.env.production

# keep example
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# OCR trained data (large binaries)
*.traineddata

# Legacy import data (photos and JSON exports)
/prisma/legacy-import/photos/
/prisma/legacy-import/candidates.json
/prisma/legacy-import/import-errors.json
